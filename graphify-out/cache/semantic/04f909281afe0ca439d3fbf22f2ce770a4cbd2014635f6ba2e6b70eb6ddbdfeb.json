{"nodes": [{"id": "guia_examen_doc", "label": "Gu\u00eda de Examen \u2014 Sistema de Parqueo USPG", "file_type": "document", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nextjs_app", "label": "Next.js Application (webapp/)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Next.js was chosen to unify frontend and backend in a single process, eliminating CORS issues and simplifying deployment on a single port (3000)."}, {"id": "prisma_orm", "label": "Prisma ORM (v6)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 6.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prisma is used as ORM to avoid raw SQL, provide type-safe JS queries, auto-generate the client from schema, and handle relational joins via include. Singleton pattern used to avoid connection pool exhaustion under Next.js HMR."}, {"id": "postgresql_db", "label": "PostgreSQL 16 (parqueo_db)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "api_routes", "label": "Next.js API Route Handlers (/api/parqueo/)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 7", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Route handlers (route.js files) export named HTTP method functions. Next.js converts them into REST endpoints automatically."}, {"id": "jwt_auth", "label": "JWT Authentication (access + refresh tokens)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "JWT payload contains only sub, email, and role \u2014 no sensitive data \u2014 because JWT is signed not encrypted and anyone can decode it. Access token expires in 1h, refresh in 7d."}, {"id": "bcrypt_password", "label": "bcrypt Password Hashing (12 rounds)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Unidirectional hash with 12 rounds of salting. Passwords never stored in plain text; bcrypt.compare used at login."}, {"id": "axios_client", "label": "Axios HTTP Client (src/lib/api.js)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 3.1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Axios instance with baseURL /api/parqueo. Request interceptor injects JWT from localStorage. Response interceptor handles 401 by clearing token and redirecting to login. 403 used for external integrations to avoid session disruption."}, {"id": "prisma_singleton", "label": "Prisma Singleton Pattern (globalThis)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 8", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Using globalThis.prisma prevents creating multiple PrismaClient instances during Next.js HMR in development, avoiding PostgreSQL connection pool exhaustion."}, {"id": "soft_delete", "label": "Soft Delete Pattern (deleted_at)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section design questions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Physical delete would orphan historical session records. soft delete preserves referential integrity while hiding records from queries via where: { deleted_at: null }."}, {"id": "iot_sensor", "label": "IoT Sensor Integration (ESP32 \u2192 /spaces/sensor)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 11 / flow questions", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "prisma_transaction", "label": "Prisma Transaction (prisma.$transaction)", "file_type": "rationale", "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 6 \u2014 DB questions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Used in vehicle entry/exit flows to ensure atomicity: if space status update fails, session creation is also rolled back, preventing inconsistent states."}], "edges": [{"source": "nextjs_app", "target": "api_routes", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 1", "weight": 1.0}, {"source": "nextjs_app", "target": "prisma_orm", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 2", "weight": 1.0}, {"source": "prisma_orm", "target": "postgresql_db", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 1", "weight": 1.0}, {"source": "prisma_singleton", "target": "prisma_orm", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 8", "weight": 1.0}, {"source": "prisma_singleton", "target": "postgresql_db", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "GUIA_EXAMEN_PARQUEO.md", "source_location": "Section 8", "weight": 0.85}, {"source": "jwt_auth", "target": "auth_module", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "GUIA_EXAMEN_PARQUE