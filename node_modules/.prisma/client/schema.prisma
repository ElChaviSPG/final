generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════

enum Role {
  ADMIN
  SECURITY
  TEACHER
  STUDENT
  VISITOR
}

enum Zone {
  A
  B
  C
  D
}

enum SpaceType {
  STANDARD
  VIP
  DISABLED
  TEACHER
}

enum SpaceStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FREE
  EXEMPT
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  TRANSFER
  QR
  APPLE_PAY
  GOOGLE_PAY
  CASH
}

enum EntryMethod {
  QR
  PLATE
  NFC
  MANUAL
  VISITOR_QR
}

enum ReservationStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum ReservationType {
  PERSONAL
  EVENT
  SPECIAL_VISIT
}

enum NotificationType {
  PARKING_FULL
  VISITOR_EXPIRING
  OVERSTAY
  INVALID_ACCESS
  PAYMENT_REQUIRED
  RESERVATION_EXPIRING
  BARRIER_ACTION
  SYSTEM_ALERT
}

enum BarrierAction {
  OPEN
  CLOSE
  BLOCK
  ERROR
}

enum TriggerSource {
  QR
  PLATE
  NFC
  MANUAL
  SYSTEM
  PAYMENT
}

enum Orientation {
  HORIZONTAL
  DIAGONAL
  VERTICAL
}

// ═══════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════

model Campus {
  id                   String   @id @default(uuid())
  name                 String
  address              String
  city                 String
  latitude             Float
  longitude            Float
  map_zoom             Int      @default(18)
  total_spaces         Int
  active               Boolean  @default(true)
  satellite_image_path String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  spaces ParkingSpace[]
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  role                   Role      @default(STUDENT)
  first_name             String
  last_name              String
  carnet                 String?   @unique
  phone                  String?
  avatar_url             String?
  nfc_card_id            String?   @unique
  qr_code                String    @unique
  qr_expires_at          DateTime
  needs_accessible_space Boolean   @default(false)
  is_active              Boolean   @default(true)
  last_login_at          DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  deleted_at             DateTime?

  vehicles           Vehicle[]
  sessions           ParkingSession[]
  payments           Payment[]
  reservations       Reservation[]
  notifications      Notification[]
  audit_logs         AuditLog[]
  visitor_qrs        VisitorQR[]      @relation("GeneratedBy")
  blacklists_added   Blacklist[]      @relation("AddedBy")
  blacklists_removed Blacklist[]      @relation("RemovedBy")
  barrier_logs       BarrierLog[]

  @@index([email])
  @@index([role])
  @@index([is_active])
}

model Vehicle {
  id               String    @id @default(uuid())
  user_id          String
  placa            String    @unique
  brand            String?
  model            String?
  color            String?
  year             Int?
  is_authorized    Boolean   @default(true)
  blacklisted      Boolean   @default(false)
  blacklist_reason String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?

  user              User             @relation(fields: [user_id], references: [id])
  sessions          ParkingSession[]
  blacklist_entries Blacklist[]

  @@index([placa])
  @@index([user_id])
  @@index([blacklisted])
}

model ParkingSpace {
  id                String      @id @default(uuid())
  code              String      @unique
  campus_id         String
  zone              Zone
  floor             Int         @default(1)
  section           String?
  type              SpaceType   @default(STANDARD)
  status            SpaceStatus @default(AVAILABLE)
  sensor_id         String?
  reserved_for_role Role?
  pos_x             Float?
  pos_y             Float?
  map_width         Float       @default(18)
  map_height        Float       @default(10)
  orientation       Orientation @default(HORIZONTAL)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  campus       Campus           @relation(fields: [campus_id], references: [id])
  sessions     ParkingSession[]
  reservations Reservation[]

  @@index([status])
  @@index([zone])
  @@index([type])
  @@index([campus_id])
}

model ParkingSession {
  id             String        @id @default(uuid())
  vehicle_id     String
  space_id       String
  user_id        String
  entry_time     DateTime      @default(now())
  exit_time      DateTime?
  entry_method   EntryMethod   @default(MANUAL)
  ticket_code    String        @unique
  ticket_qr_url  String?
  status         SessionStatus @default(ACTIVE)
  total_minutes  Int?
  total_amount   Decimal?      @db.Decimal(10, 2)
  payment_status PaymentStatus @default(PENDING)
  notes          String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  vehicle      Vehicle      @relation(fields: [vehicle_id], references: [id])
  space        ParkingSpace @relation(fields: [space_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])
  payment      Payment?
  barrier_logs BarrierLog[]
  visitor_qr   VisitorQR?

  @@index([status])
  @@index([vehicle_id])
  @@index([entry_time])
  @@index([ticket_code])
}

model Payment {
  id               String        @id @default(uuid())
  session_id       String        @unique
  user_id          String
  amount           Decimal       @db.Decimal(10, 2)
  method           PaymentMethod @default(CASH)
  status           PaymentStatus @default(PENDING)
  transaction_ref  String?
  gateway_response Json?
  paid_at          DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  session ParkingSession @relation(fields: [session_id], references: [id])
  user    User           @relation(fields: [user_id], references: [id])
}

model Reservation {
  id               String            @id @default(uuid())
  user_id          String
  space_id         String
  start_time       DateTime
  end_time         DateTime
  status           ReservationStatus @default(ACTIVE)
  reservation_type ReservationType   @default(PERSONAL)
  event_name       String?
  notes            String?
  expires_at       DateTime
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  user  User         @relation(fields: [user_id], references: [id])
  space ParkingSpace @relation(fields: [space_id], references: [id])

  @@index([status])
  @@index([user_id])
  @@index([start_time])
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String?
  type       NotificationType
  title      String
  message    String
  read       Boolean          @default(false)
  metadata   Json?
  created_at DateTime         @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([read])
  @@index([created_at])
}

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String?
  action     String
  entity     String
  entity_id  String?
  details    Json?
  ip_address String?
  user_agent String?
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([entity])
  @@index([created_at])
}

model Blacklist {
  id                 String    @id @default(uuid())
  vehicle_id         String
  reason             String
  added_by_user_id   String
  is_active          Boolean   @default(true)
  removed_at         DateTime?
  removed_by_user_id String?
  created_at         DateTime  @default(now())

  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id])
  added_by   User    @relation("AddedBy", fields: [added_by_user_id], references: [id])
  removed_by User?   @relation("RemovedBy", fields: [removed_by_user_id], references: [id])

  @@index([is_active])
  @@index([vehicle_id])
}

model BarrierLog {
  id                   String        @id @default(uuid())
  barrier_id           String
  action               BarrierAction
  triggered_by         TriggerSource
  triggered_by_user_id String?
  session_id           String?
  success              Boolean       @default(true)
  error_message        String?
  created_at           DateTime      @default(now())

  user    User?           @relation(fields: [triggered_by_user_id], references: [id])
  session ParkingSession? @relation(fields: [session_id], references: [id])

  @@index([barrier_id])
  @@index([created_at])
}

model VisitorQR {
  id                   String    @id @default(uuid())
  token                String    @unique
  generated_by_user_id String
  visitor_name         String
  visitor_doc          String?
  expires_at           DateTime
  max_hours            Int       @default(4)
  used                 Boolean   @default(false)
  used_at              DateTime?
  session_id           String?   @unique
  created_at           DateTime  @default(now())

  generated_by User            @relation("GeneratedBy", fields: [generated_by_user_id], references: [id])
  session      ParkingSession? @relation(fields: [session_id], references: [id])

  @@index([token])
  @@index([expires_at])
}

model Camera {
  id         String   @id @default(uuid())
  camera_id  String   @unique
  name       String
  location   String
  type       String   @default("LPR")
  ip_address String?
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
